# ================================================================
# Zafeer — API Server Environment Variables
# نسخ هذا الملف إلى .env وعبّئ القيم
# ================================================================

# Supabase (مطلوب)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server
NODE_ENV=development
PORT=3000

# CORS — قائمة origins مفصولة بفاصلة (production فقط)
# مثال: https://app.example.com,https://admin.example.com
# في development يُقبل كل شيء تلقائياً
# في production: فارغ = رفض كل الطلبات (الـ server يرفض الإقلاع)
ALLOWED_ORIGINS=

# Rate Limiting (admin endpoints)
# الافتراضي: 100 request/15min لكل IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ================================================================
# إنشاء أول Admin
# ================================================================
# بعد تعبئة SUPABASE_URL و SUPABASE_SERVICE_ROLE_KEY:
#   npx tsx src/scripts/seed-admin.ts
#
# أو عبّئ هذه المتغيرات قبل تشغيل السكريبت:
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=strong-password-min-8-chars
# ADMIN_FULL_NAME=مدير النظام
